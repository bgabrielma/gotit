{
  "name": "got-it",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": "22.16.0"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "purity-check": "node scripts/purity-check.mjs",
    "test:macos": "swift test --package-path apps/macos/Packages/GotItModels && swift test --package-path apps/macos/Packages/GotItInfra && swift test --package-path apps/macos/Packages/GotItUI",
    "test:macos:xcode": "xcodebuild -scheme GotIt -project apps/macos/GotIt.xcodeproj -destination 'platform=macOS,arch=arm64' test -quiet",
    "build:macos": "bash scripts/build-macos.sh",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm purity-check",
    "dev": "pnpm --filter @got-it/api dev",
    "docs:build": "mmdc -i docs/architecture.mmd -o docs/architecture.svg",
    "docs:preview": "live-server docs --port=3333",
    "prepare": "husky"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "husky": "^9",
    "lint-staged": "^15",
    "live-server": "^1.2.2",
    "prettier": "^3",
    "typescript": "^5.6",
    "vitest": "^2"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.md": ["prettier --write"]
  }
}
