# GotIt! environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Loaded by `apps/api` at startup. Adding a new env var? Update this file
# AND the spec (`docs/specs/f001-screen-capture-mvp.md` §13.x).

# ─── AI provider ──────────────────────────────────────────────
# OpenAI API key for both vision analysis and chat completions.
OPENAI_API_KEY=

# Single model id used for both screen-analysis and chat calls.
GOTIT_OPENAI_MODEL=gpt-4.1

# Connector runtime:
# - openai: uses OPENAI_API_KEY against OpenAI cloud
# - local: uses GOTIT_LLM_BASE_URL + optional GOTIT_LLM_API_KEY
GOTIT_LLM_CONNECTOR=openai

# Local OpenAI-compatible endpoint (required only when GOTIT_LLM_CONNECTOR=local),
# for example Ollama: http://localhost:11434/v1
GOTIT_LLM_BASE_URL=

# Optional local endpoint API key. If empty in local mode, server defaults to "ollama".
GOTIT_LLM_API_KEY=

# ─── Storage ──────────────────────────────────────────────────
# SQLite database path (created on first run if missing).
GOTIT_DB_PATH=./data/gotit.db

# Root directory for binary blobs (captured images, audio).
# Subfolders: images/, audio/
GOTIT_DATA_DIR=./data

# Absolute path to the Obsidian vault root. The backend writes .md files here;
# Obsidian file-watches and picks them up automatically.
GOTIT_VAULT_PATH=/Users/me/MyVault

# ─── Server ───────────────────────────────────────────────────
# Port for the Express backend.
PORT=3000

# Log level: error | warn | info | debug
LOG_LEVEL=info
