# GotIt! environment template
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Loaded by `apps/api` at startup. Adding a new env var? Update this file
# AND the spec (`docs/specs/f001-screen-capture-mvp.md` §13.x).

# ─── AI provider ──────────────────────────────────────────────
# OpenAI API key for both vision analysis and chat completions.
OPENAI_API_KEY=

# Single model id used for both screen-analysis and chat calls.
GOTIT_OPENAI_MODEL=gpt-4.1

# Connector runtime:
# - openai: uses OPENAI_API_KEY against OpenAI cloud
# - local: uses GOTIT_LLM_BASE_URL + optional GOTIT_LLM_API_KEY
GOTIT_LLM_CONNECTOR=openai

# Local OpenAI-compatible endpoint (required only when GOTIT_LLM_CONNECTOR=local),
# for example Ollama: http://localhost:11434/v1
GOTIT_LLM_BASE_URL=

# Optional local endpoint API key. If empty in local mode, server defaults to "ollama".
GOTIT_LLM_API_KEY=

# ─── Storage ──────────────────────────────────────────────────
# F014 uses one docker-compose.yml for local development and single-host production.
# Docker Compose reads this file through env_file and variable interpolation.
# For local host-based pnpm dev, put host-only overrides in .env.local, for example:
# GOTIT_DATABASE_URL=postgres://gotit:gotit@localhost:5432/gotit
#
# Start the full single-host stack:
# docker compose up -d --build
#
# Start only Postgres for host-based development:
# docker compose up -d postgres
#
# Clean reset: F014 does not migrate SQLite data. To discard all Postgres data:
# docker compose down
# docker volume rm got-it_gotit_postgres_data

# Postgres service settings used by docker-compose.yml
POSTGRES_DB=gotit
POSTGRES_USER=gotit
POSTGRES_PASSWORD=gotit
POSTGRES_PORT=5432

# Postgres connection string. Local Docker Compose default:
# postgres://gotit:gotit@localhost:5432/gotit
# Compose service-to-service URL. If running the API from the host with pnpm,
# override this in .env.local with postgres://gotit:gotit@localhost:5432/gotit.
GOTIT_DATABASE_URL=postgres://gotit:gotit@postgres:5432/gotit

# Clean reset: F014 does not migrate SQLite data. To reset storage, drop the
# Postgres database or remove the Docker volume used by Compose.
GOTIT_HOST_VAULT_PATH=./tmp/docker-vault
GOTIT_API_PORT=3000

# Root directory for binary blobs (captured images, audio).
# Subfolders: images/, audio/
GOTIT_DATA_DIR=./data

# Absolute path to the Obsidian vault root. The backend writes .md files here;
# Obsidian file-watches and picks them up automatically.
GOTIT_VAULT_PATH=/Users/me/MyVault

# ─── Web Search (SearXNG) ────────────────────────────────────
# Base URL of the SearXNG instance used for web search enrichment.
# Start SearXNG alongside Postgres: docker compose up -d searxng
GOTIT_SEARXNG_URL=http://localhost:8888

# ─── Server ───────────────────────────────────────────────────
# Port for the Express backend.
PORT=3000

# Log level: error | warn | info | debug
LOG_LEVEL=info
