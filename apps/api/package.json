{
  "name": "@got-it/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration --exclude src/__tests__/integration/llm.live.test.ts --exclude src/__tests__/integration/obsidian.live.test.ts",
    "test:live": "DOTENV_CONFIG_PATH=../../.env node -r dotenv/config ../../node_modules/vitest/vitest.mjs run src/__tests__/integration/llm.live.test.ts",
    "test:live-obsidian": "vitest run src/__tests__/integration/obsidian.live.test.ts"
  },
  "dependencies": {
    "@got-it/core": "workspace:*",
    "@got-it/shared": "workspace:*",
    "better-sqlite3": "^11",
    "dotenv": "^16",
    "express": "^4",
    "multer": "^1",
    "openai": "^6.35.0",
    "uuid": "^10",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "@types/express": "^4",
    "@types/multer": "^1",
    "@types/node": "^22",
    "@types/supertest": "^6",
    "@types/uuid": "^10",
    "supertest": "^7",
    "tsx": "^4"
  }
}
